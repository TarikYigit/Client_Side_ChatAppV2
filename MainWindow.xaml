<Window x:Class="ClientSideChatApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClientSideChatApp.ViewModels"
        xmlns:views="clr-namespace:ClientSideChatApp.Views"
        Title="Client Side Chat App" Height="450" Width="400">
        
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UserListViewModel}">
            <views:UserListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ChatViewModel}">
            <views:ChatView/>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <ContentControl Content="{Binding CurrentView}"/>
    </Grid>
</Window>