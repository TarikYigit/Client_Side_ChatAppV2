<UserControl x:Class="ClientSideChatApp.Views.AddUserToGroupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Back" Command="{Binding BackCommand}" Padding="15,5" Cursor="Hand"/>
            <TextBlock Grid.Column="1" Text="{Binding HeaderText}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0,0,0"/>
        </Grid>

        <!-- List of Users with Checkboxes -->
        <ListBox Grid.Row="1" ItemsSource="{Binding AvailableUsers}" FontSize="16">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding Username}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Add Button -->
        <Button Grid.Row="2" Content="Add Selected Users" Command="{Binding AddSelectedUsersCommand}" 
                Margin="0,20,0,0" Padding="0,15" Background="#17A2B8" Foreground="White" BorderThickness="0" FontSize="16" FontWeight="Bold" Cursor="Hand"/>
    </Grid>
</UserControl>