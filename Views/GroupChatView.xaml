<UserControl x:Class="ClientSideChatApp.Views.GroupChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:ClientSideChatApp.Helpers">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0f2027" Offset="0.0"/>
                <GradientStop Color="#203a43" Offset="0.5"/>
                <GradientStop Color="#2c5364" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Background="#1E1E24" CornerRadius="15" Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="8" Opacity="0.4" Color="Black"/>
            </Border.Effect>

            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Command="{Binding BackCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="#2A2A35" CornerRadius="6" Padding="15,8">
                                    <TextBlock Text="Back" Foreground="White" FontSize="13" FontWeight="Bold"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#3A3A45"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock Grid.Column="1" Text="{Binding HeaderText}" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0,0,0"/>

                    <Button Grid.Column="2" Command="{Binding AddUserToGroupCommand}" Margin="0,0,10,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="#17A2B8" CornerRadius="6" Padding="15,8">
                                    <TextBlock Text="Add User" Foreground="White" FontSize="13" FontWeight="Bold"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#138496"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="3" Command="{Binding LeaveGroupCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="#DC3545" CornerRadius="6" Padding="15,8">
                                    <TextBlock Text="Leave Group" Foreground="White" FontSize="13" FontWeight="Bold"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#C82333"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Chat History -->
                <ListBox Grid.Row="1" ItemsSource="{Binding Messages}" 
                         helpers:AutoScrollHelper.AutoScroll="True" 
                         Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5,5,5,10">
                                <Border x:Name="BubbleBorder" CornerRadius="12,12,12,0" Padding="12" MaxWidth="400" HorizontalAlignment="Left" Background="#2A2A35">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <!-- THE FIX: Bright Ice Blue for the sender's name -->
                                            <TextBlock x:Name="SenderText" Text="{Binding Sender}" FontWeight="Bold" FontSize="13" Foreground="#4DB8FF"/>

                                            <!-- THE FIX: Crisp Light Gray for the default incoming time -->
                                            <TextBlock x:Name="TimeText" Text="{Binding Timestamp}" FontSize="11" Foreground="#A0A0A0" Margin="10,0,0,0" VerticalAlignment="Center"/>

                                            <TextBlock x:Name="TickText" FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center" FontWeight="Bold" Visibility="Collapsed">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="✓"/>
                                                        <Setter Property="Foreground" Value="#D9EBFF"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSent}" Value="True">
                                                                <Setter Property="Text" Value="✓✓"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsSeen}" Value="True">
                                                                <Setter Property="Text" Value="✓✓"/>
                                                                <Setter Property="Foreground" Value="#000000"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- FIXED TYPO: Removed the period from StackPanel -->
                                        </StackPanel>

                                        <TextBlock Text="{Binding Content}" FontSize="15" Foreground="White" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMyMessage}" Value="True">
                                    <Setter TargetName="BubbleBorder" Property="HorizontalAlignment" Value="Right"/>
                                    <Setter TargetName="BubbleBorder" Property="Background" Value="#0078D7"/>
                                    <Setter TargetName="BubbleBorder" Property="CornerRadius" Value="12,12,0,12"/>
                                    <Setter TargetName="SenderText" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="TickText" Property="Visibility" Value="Visible"/>

                                    <!-- THE FIX: Swap the timestamp to Pale White when the bubble is blue -->
                                    <Setter TargetName="TimeText" Property="Foreground" Value="#D9EBFF"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Input Area -->
                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#2A2A35" CornerRadius="8" Padding="12,10">
                        <TextBox Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" Foreground="White" Background="Transparent" BorderThickness="0" CaretBrush="White" FontSize="15"/>
                    </Border>
                    <Button Grid.Column="1" Command="{Binding SendCommand}" Margin="10,0,0,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="#0078D7" CornerRadius="8">
                                    <TextBlock Text="Send" Foreground="White" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#005A9E"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>