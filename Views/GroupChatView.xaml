<UserControl x:Class="ClientSideChatApp.Views.GroupChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: Back Button, Title, and Group Controls -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- Back -->
                <ColumnDefinition Width="*"/>
                <!-- Group Name -->
                <ColumnDefinition Width="Auto"/>
                <!-- Add -->
                <ColumnDefinition Width="Auto"/>
                <!-- Leave -->
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Back" Command="{Binding BackCommand}" Padding="15,5" Cursor="Hand"/>
            <TextBlock Grid.Column="1" Text="{Binding HeaderText}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0,0,0"/>

            <Button Grid.Column="2" Content="Add User" Command="{Binding AddUserToGroupCommand}" 
                    Margin="0,0,10,0" Padding="15,5" Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"/>

            <Button Grid.Column="3" Content="Leave Group" Command="{Binding LeaveGroupCommand}" 
                    Padding="15,5" Background="#DC3545" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </Grid>

        <!-- Chat History -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Messages}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <!-- In a group, seeing the sender's name is critical -->
                            <TextBlock Text="{Binding Sender}" FontWeight="Bold" FontSize="12" Foreground="#0078D7"/>
                            <TextBlock Text="{Binding Timestamp}" FontSize="10" Foreground="DarkGray" Margin="10,0,0,0" VerticalAlignment="Bottom"/>

                            <!-- State Machine Tick System -->
                            <TextBlock FontSize="10" Margin="4,0,0,0" VerticalAlignment="Bottom">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="✓"/>
                                        <!-- Default: Just Sent to Server -->
                                        <Setter Property="Foreground" Value="DarkGray"/>
                                        <Style.Triggers>
                                            <!-- Delivered to Vault -->
                                            <DataTrigger Binding="{Binding IsSent}" Value="True">
                                                <Setter Property="Text" Value="✓✓"/>
                                            </DataTrigger>
                                            <!-- Read by User -->
                                            <DataTrigger Binding="{Binding IsSeen}" Value="True">
                                                <Setter Property="Text" Value="✓✓"/>
                                                <Setter Property="Foreground" Value="#0078D7"/>
                                                <!-- Blue color -->
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                        </StackPanel>
                        <TextBlock Text="{Binding Content}" FontSize="16" Margin="0,2,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Input Area -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="16"/>
            <Button Grid.Column="1" Content="Send" Command="{Binding SendCommand}" Margin="5,0,0,0" 
                    Background="#0078D7" Foreground="White" BorderThickness="0" FontSize="16" Cursor="Hand"/>
        </Grid>
    </Grid>
</UserControl>