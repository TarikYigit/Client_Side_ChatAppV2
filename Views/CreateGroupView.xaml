<UserControl x:Class="ClientSideChatApp.Views.CreateGroupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Back" Command="{Binding BackCommand}" Padding="15,5" Cursor="Hand"/>
            <TextBlock Grid.Column="1" Text="Create New Group" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0,0,0"/>
        </Grid>

        <!-- Group Name Input -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <TextBox x:Name="GroupNameBox" Text="{Binding GroupName, UpdateSourceTrigger=PropertyChanged}" 
                     Padding="10" FontSize="16" HorizontalAlignment="Stretch"/>
            <TextBlock IsHitTestVisible="False" Text="Enter group name..." 
                       VerticalAlignment="Center" Margin="12,0,0,0" Foreground="Gray" FontSize="16">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=GroupNameBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Select Users List -->
        <TextBlock Grid.Row="2" Text="Select Members:" FontSize="16" FontWeight="Bold" Margin="0,0,0,5" VerticalAlignment="Top"/>
        <ListBox Grid.Row="2" ItemsSource="{Binding AvailableUsers}" Margin="0,30,0,0" FontSize="16">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding Username}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Action Button -->
        <Button Grid.Row="3" Content="Create Group" Command="{Binding ExecuteCreateGroupCommand}" 
                Margin="0,20,0,0" Padding="0,15" FontSize="16" FontWeight="Bold" 
                Background="#0078D7" Foreground="White" BorderThickness="0" Cursor="Hand"/>
    </Grid>
</UserControl>